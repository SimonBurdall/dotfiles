################
# NVIDIA       #
################
env = LIBVA_DRIVER_NAME,nvidia
env = XDG_SESSION_TYPE,wayland
env = GBM_BACKEND,nvidia-drm
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = NVD_BACKEND,direct

source = ~/.cache/wal/colors-hyprland.conf

cursor {
    no_hardware_cursors = true
}

##############
# MONITOR    #
##############
monitor = DP-3,5120x1440@239.76,0x0,1

##############
# AUTOSTART  #
##############
exec-once = swaync
exec-once = hypridle
exec-once = waybar
exec-once = swaybg -i $(cat ~/.cache/wal/wal) -m fill
#exec-once = swaybg -i /home/si/1-vault/2-media/1-wallpapers/wpa.png -m fill

##############
# INPUT      #
##############
input {
    kb_layout = gb
    follow_mouse = 1
    sensitivity = 0
}

##############
# GENERAL    #
##############
general {
    gaps_in = 5
    gaps_out = 10
    border_size = 2
    col.active_border = $color6
    col.inactive_border = $color2
    layout = dwindle
}

##############
# CURSOR     #
##############
env = XCURSOR_THEME,Bibata-Modern-Classic
env = XCURSOR_SIZE,24

cursor {
    no_hardware_cursors = true
}

##############
# DECORATION #
##############
decoration {
    rounding = 4
    active_opacity = 1.0
    inactive_opacity = 1.0
    blur {
        enabled = true
        size = 3
        passes = 1
    }
}

##############
# ANIMATIONS #
##############
animations {
    enabled = true
    bezier = myBezier, 0.05, 0.9, 0.1, 1.05
    animation = windows, 1, 7, myBezier
    animation = fade, 1, 7, default
    animation = workspaces, 1, 6, default
}

##############
# LAYOUT     #
##############
dwindle {
    preserve_split = true
}

##############
# KEYBINDS   #
##############
$mod = SUPER

# --- APPLICATIONS ---
bind = $mod, Return, exec, kitty
bind = $mod, Tab, exec, kitty
bind = $mod, Space, exec, rofi -show drun

# app shortcuts — matching your old super + {6,7,8,9,0,minus}
bind = $mod, 6, exec, spotify
bind = $mod, 7, exec, floorp
bind = $mod, 8, exec, discord
bind = $mod, 9, exec, steam
bind = $mod, 0, exec, obsidian
bind = $mod, minus, exec, keepassxc

# Moonlander app shortcuts
bind = CTRL SHIFT ALT SUPER, h, exec, spotify
bind = CTRL SHIFT ALT SUPER, j, exec, floorp
bind = CTRL SHIFT ALT SUPER, k, exec, discord
bind = CTRL SHIFT ALT SUPER, l, exec, steam
bind = CTRL SHIFT ALT SUPER, semicolon, exec, obsidian
bind = CTRL SHIFT ALT SUPER, apostrophe, exec, keepassxc

# --- SYSTEM ---
bind = $mod CTRL, Escape, exec, ~/.config/hypr/scripts/powermenu.sh
bind = CTRL SHIFT ALT SUPER, p, exec, ~/.config/hypr/scripts/powermenu.sh
bind = $mod, N, exec, swaync-client -t

# --- SCREENSHOTS ---
bind = , Print, exec, grim -g "$(slurp)" ~/Pictures/$(date +%Y%m%d_%H%M%S).png
bind = SHIFT, Print, exec, grim ~/Pictures/$(date +%Y%m%d_%H%M%S).png
bind = $mod, S, exec, grim -g "$(slurp)" - | wl-copy

# --- WINDOW MANAGEMENT ---
bind = $mod, C, killactive
bind = $mod SHIFT, W, killactive
bind = $mod, V, togglefloating
bind = $mod, F, fullscreen

# --- FOCUS --- (hjkl matching your old bspwm binds)
bind = $mod, h, movefocus, l
bind = $mod, j, movefocus, d
bind = $mod, k, movefocus, u
bind = $mod, l, movefocus, r
bind = $mod, left, movefocus, l
bind = $mod, right, movefocus, r
bind = $mod, up, movefocus, u
bind = $mod, down, movefocus, d

# --- MOVE WINDOWS ---
bind = $mod SHIFT, h, movewindow, l
bind = $mod SHIFT, j, movewindow, d
bind = $mod SHIFT, k, movewindow, u
bind = $mod SHIFT, l, movewindow, r
bind = $mod SHIFT, left, movewindow, l
bind = $mod SHIFT, right, movewindow, r
bind = $mod SHIFT, up, movewindow, u
bind = $mod SHIFT, down, movewindow, d

# --- RESIZE ---
bind = $mod ALT, h, resizeactive, -50 0
bind = $mod ALT, j, resizeactive, 0 50
bind = $mod ALT, k, resizeactive, 0 -50
bind = $mod ALT, l, resizeactive, 50 0
bind = $mod ALT, left, resizeactive, -50 0
bind = $mod ALT, right, resizeactive, 50 0
bind = $mod ALT, up, resizeactive, 0 -50
bind = $mod ALT, down, resizeactive, 0 50

# --- WORKSPACES ---
bind = $mod, 1, workspace, 1
bind = $mod, 2, workspace, 2
bind = $mod, 3, workspace, 3
bind = $mod, 4, workspace, 4
bind = $mod, 5, workspace, 5

# Moonlander workspace focus
bind = CTRL SHIFT ALT SUPER, a, workspace, 1
bind = CTRL SHIFT ALT SUPER, s, workspace, 2
bind = CTRL SHIFT ALT SUPER, d, workspace, 3
bind = CTRL SHIFT ALT SUPER, f, workspace, 4
bind = CTRL SHIFT ALT SUPER, g, workspace, 5

# move windows to workspaces
bind = $mod SHIFT, 1, movetoworkspace, 1
bind = $mod SHIFT, 2, movetoworkspace, 2
bind = $mod SHIFT, 3, movetoworkspace, 3
bind = $mod SHIFT, 4, movetoworkspace, 4
bind = $mod SHIFT, 5, movetoworkspace, 5

# Moonlander move to workspace
bind = $mod SHIFT, a, movetoworkspace, 1
bind = $mod SHIFT, s, movetoworkspace, 2
bind = $mod SHIFT, d, movetoworkspace, 3
bind = $mod SHIFT, f, movetoworkspace, 4
bind = $mod SHIFT, g, movetoworkspace, 5
# cycle desktops
bind = $mod, comma, workspace, e-1
bind = $mod, period, workspace, e+1

# alt+tab style
bind = ALT, Tab, cyclenext
bind = ALT SHIFT, Tab, cyclenext, prev

# --- MOUSE ---
bindm = $mod, mouse:272, movewindow
bindm = $mod, mouse:273, resizewindow

# --- AUDIO ---
bind = , XF86AudioRaiseVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bind = , XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bind = , XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bind = $mod SHIFT, equal, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bind = $mod SHIFT, minus, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bind = $mod SHIFT, m, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bind = , XF86AudioPlay, exec, playerctl play-pause
bind = SUPER, XF86AudioPlay, exec, playerctl -a stop
bind = , XF86AudioPrev, exec, playerctl previous
bind = , XF86AudioNext, exec, playerctl next
