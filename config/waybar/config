{
  "layer": "top",
  "position": "top",
  "height": 36,
  "margin-top": 0,
  "spacing": 0,

  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "custom/tasks",
    "custom/notifications",
    "bluetooth",
    "network"
  ],
  "modules-center": ["custom/mpris"],
  "modules-right": [
    "pulseaudio",
    "battery",
    "custom/sysmon",
    "clock",
    "custom/power"
  ],

  "custom/launcher": {
    "format": "َ°چ‰",
    "tooltip": false,
    "on-click": "rofi -show drun"
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "custom/tasks": {
    "format": "ï‚®<sup>{}</sup>",
    "exec": "~/.config/waybar/scripts/tasks-count.sh",
    "interval": 300,
    "tooltip": false,
    "on-click": "xdg-open https://todoist.com/app"
  },

  "custom/notifications": {
    "format": "{icon}<sup>{text}</sup>",
    "format-icons": {
      "notification": "َ±µ«",
      "none": "َ°‚ڑ",
      "dnd-notification": "َ°‚›",
      "dnd-none": "َ°‚›"
    },
    "return-type": "json",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
    "tooltip": false
  },

  "bluetooth": {
    "format": "َ°‚ڈ",
    "format-disabled": "َ°‚’",
    "format-connected": "َ°‚‘",
    "tooltip-format": "{device_alias}",
    "on-click": "blueman-manager"
  },

  "network": {
    "format-wifi": "َ°–©",
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "َ°–ھ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}",
    "on-click": "nm-connection-editor"
  },

  "custom/mpris": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/mpris-or-quote.sh",
    "interval": 2,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "max-length": 48,
    "escape": true
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں muted",
    "format-icons": { "default": ["َ°•؟", "َ°–€", "َ°•¾"] },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": ["َ°پ؛", "َ°پ¼", "َ°پ¾", "َ°‚€", "َ°‚‚"],
    "states": { "warning": 30, "critical": 15 },
    "tooltip": false
  },

  "custom/sysmon": {
    "format": "{}",
    "interval": 3,
    "exec": "~/.config/waybar/scripts/sysmon.sh",
    "return-type": "json",
    "on-click": "kitty -e btop"
  },

  "clock": {
    "format": "َ°¥” {:%H:%M  %d/%m/%Y}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "custom/power": {
    "format": "َ°گ¥",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/powermenu.sh"
  }
}
