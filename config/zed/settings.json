// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "buffer_font_weight": 400.0,
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "ollama",
      "model": "qwen3:8b",
      "enable_thinking": true
    },
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "edit_file": {
          "default": "confirm",
          "always_deny": [
            { "pattern": "\\.env" },
            { "pattern": "secrets?/" },
            { "pattern": "\\.(pem|key)$" }
          ]
        },
        "delete_path": {
          "default": "confirm",
          "always_deny": [ { "pattern": "\\.git/?$" } ]
        },
        "terminal": {
          "default": "confirm",
          "always_deny": [ { "pattern": "\\bgit\\s+push\\b" } ],
          "always_confirm": [ { "pattern": "\\bgit\\s+commit\\b" } ]
        }
      }
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "ui_font_size": 12.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  }
}
